tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"gold"},{"text":"Pool and Billiards Datapack User Guide","color":"gold"}]

tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"yellow"},{"text":"Before playing"}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    Please make sure you are using the matching datapack version for your Minecraft version."}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    When installing for the first time, required configurations will be prompted automatically."}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    Please make sure the resource pack is enabled. On servers, both the server setup and your client resource pack may matter."}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    If you are on a server and cannot access all settings, your permissions may be restricted. Please contact a server OP."}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    Click "},{"underlined":true,"text":"<Buttons>"},{"underlined":false,"text":" like this to interact with the datapack."}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    Get a cue stick and place a pool table before playing."}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    Except for practice mode, games should be started from the lobby."}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    Check the Games and Rules information in the lobby page if needed."}]

tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"yellow"},{"text":"While playing"}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    Hold the cue stick in your main hand. When the cue ball is on the table and not moving, press shift to face the cue ball, then move around until your line of sight matches the aiming direction you want."}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    Right click with the cue stick to charge, and release to shoot. The longer you charge, the stronger the shot."}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    You can adjust the cue-ball hit point, cue-stick elevation angle, and other shot settings before shooting. These settings reset after each shot."}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    If the cue ball is not on the table, you or your opponent will receive a cue ball according to any enforced rules. Hold it in your main hand and sweep across the table. Green particles indicate valid placement locations;"}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    Right click to place the cue ball. For accurate cue-ball placement, stand on the table or on the ground near the table."}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    Please wait for all balls to stop moving before the next shot. Like a real table, the game is not fully locked during play, so interruptions can happen. Please be patient while other players act."}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    Different cue sticks and table appearances are cosmetic only and do not change gameplay behavior."}]

tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"yellow"},{"text":"After playing"}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    It is intentional that the final shot cannot be undone."}]
tellraw @s[tag=swPool_EN] [{"text":"➇ ","color":"white"},{"text":"    If you are leaving the area, remove the table to avoid leaving many entities behind."}]

tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"gold"},{"text":"台球数据包用户指南","color":"gold"}]

tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"yellow"},{"text":"游玩前"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    请确认你正在使用与 Minecraft 版本匹配的数据包版本。"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    第一次安装时，必须设置的配置项会自动提示。"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    请确认资源包已经启用。 在服务器游玩时， 服务器设置和你的客户端资源包都可能影响显示。"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    如果你在服务器中无法访问所有设置，可能是权限受限。 请联系服务器管理员。"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    请点击类似 "},{"underlined":true,"text":"<按钮>"},{"underlined":false,"text":" 的文字与数据包交互。"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    游玩前请先获取球杆并放置球桌。"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    除练习模式外，正式游戏需要从大厅开始。"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    如有需要，请在大厅页面查看游戏模式和规则说明。"}]

tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"yellow"},{"text":"游玩中"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    主手持球杆。 当母球在球桌上且没有移动时， 按住 shift 可面向母球， 之后移动位置，直到视线方向与所需的瞄准方向一致。"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    主手持球杆右键蓄力，松开右键击球。 蓄力时间越长， 击球力度越大。"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    击球前可以调整母球击打点、球杆抬高角度和其他击球设置。 这些设置会在每次击球后重置。"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    如果母球不在球桌上，根据规则， 你或你的对手会获得一颗母球。 主手持母球扫过球桌， 绿色粒子表示可以放置的位置；"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    右键放置母球。 为了更准确地放置母球， 请站在球桌上， 或站在球桌附近的地面上。"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    下一杆前请等待所有球完全停止。 和真实球桌类似， 游玩过程中球桌不会被完全锁定，所以仍可能被打断。 其他玩家操作时请耐心等待。"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    不同球杆和球桌外观仅为视觉差异， 不会改变实际玩法。"}]

tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"yellow"},{"text":"游玩后"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    最后一杆不能撤回， 这是有意设计。"}]
tellraw @s[tag=swPool_CN] [{"text":"➇ ","color":"white"},{"text":"    如果你要离开这片区域， 可以移除球桌，避免留下大量实体。"}]

